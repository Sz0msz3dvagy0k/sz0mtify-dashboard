{
  "name": "music-dashboard-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && vite dev",
    "build": "vite build",
    "build:mobile": "vite build && cap sync ios",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:ios": "npm run build:mobile && cap open ios",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.0.0",
    "@types/node": "^25.6.2",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/network": "^8.0.1",
    "date-fns": "^4.0.0",
    "echarts": "^5.5.0",
    "lucide-svelte": "^0.460.0"
  }
}
