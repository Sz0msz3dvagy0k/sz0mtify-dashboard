{
  "name": "music-dashboard-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-capacitor-ios-plugins.mjs",
    "patch:ios-plugins": "node scripts/patch-capacitor-ios-plugins.mjs",
    "dev": "svelte-kit sync && vite dev",
    "build": "vite build",
    "build:mobile": "vite build && npm run patch:ios-plugins && cap sync ios",
    "cap:add:ios": "cap add ios",
    "cap:sync": "npm run patch:ios-plugins && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:ios": "npm run build:mobile && cap open ios",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && npm run lint",
    "lint": "eslint . && npm run lint:styles",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "format": "prettier --write .",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.0.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.6.2",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capgo/native-audio": "^8.4.2",
    "@tauri-apps/api": "^2.11.0",
    "date-fns": "^4.0.0",
    "echarts": "^5.5.0",
    "lucide-svelte": "^0.460.0"
  }
}
